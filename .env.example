# Video frame analysis (Stage 1)
# Set BASE_URL to your company AI gateway; leave empty to connect directly to the vendor.
VIDEO_ANALYSIS_BASE_URL=
VIDEO_ANALYSIS_API_KEY=
VIDEO_ANALYSIS_MODEL=gemini-2.5-flash

# HTML generation (Stage 2a)
HTML_GEN_BASE_URL=
HTML_GEN_API_KEY=
HTML_GEN_MODEL=claude-sonnet-4-6

# Optional: Pexels stock footage search (skipped if empty)
PEXELS_API_KEY=

# Optional: scene-change detection sensitivity (lower = more frames)
SCENE_THRESHOLD=0.35
