# ── Video frame analysis (Stage 1 · OpenAI-compatible · Gemini) ──────────────
# Gateway:  VIDEO_ANALYSIS_BASE_URL=http://aigateway.example.com/vertex/v1
#           OpenAI SDK appends /chat/completions, so base_url MUST include /v1
# Direct:   leave empty → code auto-sets Gemini OpenAI-compatible endpoint
VIDEO_ANALYSIS_BASE_URL=
VIDEO_ANALYSIS_API_KEY=
# Gateway model name: gemini-2.5-flash  (or gemini-3.5-flash if supported)
# Direct model name:  gemini-2.5-flash
VIDEO_ANALYSIS_MODEL=gemini-2.5-flash

# ── HTML generation (Stage 2a · Anthropic Messages API · Claude) ──────────────
# Gateway:  HTML_GEN_BASE_URL=http://aigateway.example.com/bedrock/
#           Anthropic SDK appends v1/messages, so base_url should NOT include /v1
# Direct:   leave empty → Anthropic SDK uses api.anthropic.com automatically
HTML_GEN_BASE_URL=
HTML_GEN_API_KEY=
# Gateway model name: global.anthropic.claude-sonnet-4-6
# Direct model name:  claude-sonnet-4-6
HTML_GEN_MODEL=claude-sonnet-4-6

# ── Optional ──────────────────────────────────────────────────────────────────
PEXELS_API_KEY=
SCENE_THRESHOLD=0.35
